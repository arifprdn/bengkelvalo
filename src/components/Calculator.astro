---
import { t } from '../data/i18n.js'
import WaIcon from './WaIcon.astro'
const { lang = 'id' } = Astro.props
---
<section class="calculator-section" id="calculator">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{t('calc.badge', lang)}</span>
            <h2 class="section-title" set:html={t('calc.title', lang)} />
            <p class="section-description">{t('calc.description', lang)}</p>
        </div>

        <!-- Tab Toggle -->
        <div class="calc-tabs" role="tablist">
            <button type="button" class="calc-tab active" data-tab="reguler" id="tab-reguler" role="tab"
                aria-selected="true" aria-controls="panel-reguler">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    aria-hidden="true">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
                <span>{t('calc.tab.reguler', lang)}</span>
            </button>
            <button type="button" class="calc-tab" data-tab="mabar" id="tab-mabar" role="tab" aria-selected="false"
                aria-controls="panel-mabar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    aria-hidden="true">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                <span>{t('calc.tab.mabar', lang)}</span>
            </button>
        </div>

        <!-- Tab Panel: Joki Reguler -->
        <div class="calc-tab-panel active" id="panel-reguler" role="tabpanel" aria-labelledby="tab-reguler">
            <div class="rank-preview-bar" id="rank-preview-bar"></div>
            <div class="calculator-card">
                <div class="calculator-grid">
                    <!-- From Rank -->
                    <div class="rank-selector">
                        <h3 class="selector-title">
                            <span>{t('calc.currentRank', lang)}</span>
                        </h3>
                        <div class="rank-picker" id="from-rank-picker">
                            <div class="selected-rank" id="from-selected" role="button" tabindex="0"
                                aria-haspopup="listbox" aria-expanded="false">
                                <img src="/assets/1 - IRON.webp" alt="Iron" class="selected-rank-img" width="60"
                                    height="60" />
                                <div class="selected-rank-info">
                                    <span class="selected-rank-name">Iron</span>
                                    <span class="selected-rank-division">Division 1</span>
                                </div>
                                <svg class="dropdown-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </div>
                            <div class="rank-dropdown" id="from-dropdown">
                                <div class="rank-options" id="from-options"></div>
                            </div>
                        </div>
                        <div class="division-selector" id="from-division">
                            <button type="button" class="division-btn active" data-division="1">I</button>
                            <button type="button" class="division-btn" data-division="2">II</button>
                            <button type="button" class="division-btn" data-division="3">III</button>
                        </div>
                        <div class="rr-input-container" id="from-regular-rr-container">
                            <label class="rr-label" for="from-regular-rr">{t('calc.currentRR', lang)}</label>
                            <div class="rr-input-wrapper">
                                <input type="number" class="rr-input" id="from-regular-rr" min="0" max="99" value="0"
                                    placeholder="0">
                                <span class="rr-suffix">RR</span>
                            </div>
                        </div>
                        <div class="rr-input-container" id="from-rr-container" style="display: none;">
                            <label class="rr-label" for="from-rr">Rating Points (RR)</label>
                            <div class="rr-input-wrapper">
                                <input type="number" class="rr-input" id="from-rr" min="400" max="1000" value="400"
                                    placeholder="400">
                                <span class="rr-suffix">RR</span>
                            </div>
                        </div>
                    </div>

                    <!-- Arrow -->
                    <div class="calculator-arrow">
                        <div class="arrow-circle">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" aria-hidden="true">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </div>
                    </div>

                    <!-- To Rank -->
                    <div class="rank-selector">
                        <h3 class="selector-title">
                            <span>{t('calc.targetRank', lang)}</span>
                        </h3>
                        <div class="rank-picker" id="to-rank-picker">
                            <div class="selected-rank" id="to-selected" role="button" tabindex="0"
                                aria-haspopup="listbox" aria-expanded="false">
                                <img src="/assets/4 - GOLD.webp" alt="Gold" class="selected-rank-img" width="60"
                                    height="60" />
                                <div class="selected-rank-info">
                                    <span class="selected-rank-name">Gold</span>
                                    <span class="selected-rank-division">Division 1</span>
                                </div>
                                <svg class="dropdown-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </div>
                            <div class="rank-dropdown" id="to-dropdown">
                                <div class="rank-options" id="to-options"></div>
                            </div>
                        </div>
                        <div class="division-selector" id="to-division">
                            <button type="button" class="division-btn active" data-division="1">I</button>
                            <button type="button" class="division-btn" data-division="2">II</button>
                            <button type="button" class="division-btn" data-division="3">III</button>
                        </div>
                        <div class="rr-input-container" id="to-rr-container" style="display: none;">
                            <label class="rr-label" for="to-rr">Rating Points (RR)</label>
                            <div class="rr-input-wrapper">
                                <input type="number" class="rr-input" id="to-rr" min="400" max="1000" value="500"
                                    placeholder="500">
                                <span class="rr-suffix">RR</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RR Info Display -->
                <div class="rr-info-bar" id="rr-info-bar" style="display: none;">
                    <div class="rr-info-content">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="16" x2="12" y2="12" />
                            <line x1="12" y1="8" x2="12.01" y2="8" />
                        </svg>
                        <span id="rr-info-text">RR Awal: 0 â†’ RR Akhir: 0</span>
                    </div>
                </div>

                <!-- Add-ons -->
                <div class="addons-section">
                    <h4 class="addons-title">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true">
                            <path d="M12 2v20M2 12h20" />
                        </svg>
                        Add-ons
                    </h4>
                    <div class="addons-grid">
                        <label class="addon-item" for="addon-offline">
                            <input type="checkbox" id="addon-offline" class="addon-checkbox" />
                            <div class="addon-content">
                                <div class="addon-info">
                                    <span class="addon-name">{t('addon.offline.name', lang)}</span>
                                    <span class="addon-desc">{t('addon.offline.desc', lang)}</span>
                                </div>
                                <span class="addon-price">{t('addon.offline.price', lang)}</span>
                            </div>
                        </label>
                        <label class="addon-item" for="addon-agent">
                            <input type="checkbox" id="addon-agent" class="addon-checkbox" />
                            <div class="addon-content">
                                <div class="addon-info">
                                    <span class="addon-name">{t('addon.agent.name', lang)}</span>
                                    <span class="addon-desc">{t('addon.agent.desc', lang)}</span>
                                </div>
                                <span class="addon-price">{t('addon.agent.price', lang)}</span>
                            </div>
                        </label>
                        <label class="addon-item" for="addon-priority">
                            <input type="checkbox" id="addon-priority" class="addon-checkbox" />
                            <div class="addon-content">
                                <div class="addon-info">
                                    <span class="addon-name">{t('addon.priority.name', lang)}</span>
                                    <span class="addon-desc">{t('addon.priority.desc', lang)}</span>
                                </div>
                                <span class="addon-price">{t('addon.priority.price', lang)}</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Price Display -->
                <div class="price-display">
                    <div class="price-info">
                        <span class="price-label">{t('price.label', lang)}</span>
                        <div class="original-price" id="original-price"></div>
                        <div class="price-amount">
                            <span class="currency">Rp</span>
                            <span class="price-value" id="price-value">80,000</span>
                        </div>
                        <div class="discount-badge" id="discount-badge"></div>
                        <span class="price-note">{t('price.note', lang)}</span>
                    </div>
                    <a href="https://wa.me/6289524150075?text=Halo%20BengkelValo,%20saya%20ingin%20order%20rank%20up"
                        target="_blank" rel="noopener" class="btn btn-primary btn-lg order-btn" id="order-btn">
                        <WaIcon size={24} />
                        <span>{t('price.order', lang)}</span>
                    </a>
                </div>

                <div class="calculator-features">
                    <div class="calc-feature">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                        <span>{t('calc.safe', lang)}</span>
                    </div>
                    <div class="calc-feature">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                        <span>{t('calc.fast', lang)}</span>
                    </div>
                    <div class="calc-feature">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        <span>{t('calc.guarantee', lang)}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab Panel: Joki Mabar -->
        <div class="calc-tab-panel" id="panel-mabar" role="tabpanel" aria-labelledby="tab-mabar">

            <!-- Gendong Sub-tabs -->
            <div class="duo-subtabs" role="tablist">
                <button type="button" class="duo-subtab active" data-duotab="perwin" id="subtab-perwin" role="tab"
                    aria-selected="true" aria-controls="duo-panel-perwin">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                    </svg>
                    <span>{t('duo.subtab.perwin', lang)}</span>
                </button>
                <button type="button" class="duo-subtab" data-duotab="perrank" id="subtab-perrank" role="tab"
                    aria-selected="false" aria-controls="duo-panel-perrank">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                        <polyline points="17 6 23 6 23 12" />
                    </svg>
                    <span>{t('duo.subtab.perrank', lang)}</span>
                </button>
            </div>

            <!-- Sub-panel: Per Win -->
            <div class="duo-subpanel active" id="duo-panel-perwin" role="tabpanel" aria-labelledby="subtab-perwin">
                <div class="calculator-card duo-card">
                    <div class="duo-calculator-grid">
                        <div class="rank-selector">
                            <h3 class="selector-title">
                                <span>{t('duo.rankLabel', lang)}</span>
                            </h3>
                            <div class="rank-picker" id="duo-rank-picker">
                                <div class="selected-rank" id="duo-selected" role="button" tabindex="0"
                                    aria-haspopup="listbox" aria-expanded="false">
                                    <img src="/assets/1 - IRON.webp" alt="Iron" class="selected-rank-img" width="60"
                                        height="60" />
                                    <div class="selected-rank-info">
                                        <span class="selected-rank-name">Iron</span>
                                        <span class="selected-rank-division">Division 1</span>
                                    </div>
                                    <svg class="dropdown-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M6 9l6 6 6-6" />
                                    </svg>
                                </div>
                                <div class="rank-dropdown" id="duo-dropdown">
                                    <div class="rank-options" id="duo-options"></div>
                                </div>
                            </div>
                            <div class="division-selector" id="duo-division">
                                <button type="button" class="division-btn active" data-division="1">I</button>
                                <button type="button" class="division-btn" data-division="2">II</button>
                                <button type="button" class="division-btn" data-division="3">III</button>
                            </div>
                        </div>
                        <div class="rank-selector">
                            <h3 class="selector-title">
                                <span>{t('duo.winLabel', lang)}</span>
                            </h3>
                            <div class="game-count-wrapper">
                                <button type="button" class="game-count-btn" id="duo-minus"
                                    aria-label={lang === 'id' ? 'Kurangi jumlah win' : 'Decrease number of wins'}>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" aria-hidden="true">
                                        <line x1="5" y1="12" x2="19" y2="12" />
                                    </svg>
                                </button>
                                <input type="number" class="game-count-input" id="duo-games" min="1" max="6" value="1"
                                    aria-label={lang === 'id' ? 'Jumlah win' : 'Number of wins'} />
                                <button type="button" class="game-count-btn" id="duo-plus"
                                    aria-label={lang === 'id' ? 'Tambah jumlah win' : 'Increase number of wins'}>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" aria-hidden="true">
                                        <line x1="12" y1="5" x2="12" y2="19" />
                                        <line x1="5" y1="12" x2="19" y2="12" />
                                    </svg>
                                </button>
                            </div>
                            <div class="duo-price-per-game" id="duo-price-per-game">Rp 10.000 Ã— 1 win</div>
                        </div>
                    </div>
                    <div class="price-display duo-price-display">
                        <div class="price-info">
                            <span class="price-label">{t('duo.priceLabel', lang)}</span>
                            <div class="price-amount">
                                <span class="currency">Rp</span>
                                <span class="price-value" id="duo-price-value">10,000</span>
                            </div>
                            <span class="price-note">{t('duo.priceNote', lang)}</span>
                        </div>
                        <a href="#" target="_blank" rel="noopener" class="btn btn-primary btn-lg order-btn"
                            id="duo-order-btn">
                            <WaIcon size={24} />
                            <span>{t('duo.order', lang)}</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Sub-panel: Per Rank (clone of reguler, price Ã— 2) -->
            <div class="duo-subpanel" id="duo-panel-perrank" role="tabpanel" aria-labelledby="subtab-perrank">
                <div class="calculator-card duo-card">
                    <div class="calculator-grid">
                        <!-- From Rank -->
                        <div class="rank-selector">
                            <h3 class="selector-title">
                                <span>{t('duo.perrank.from', lang)}</span>
                            </h3>
                            <div class="rank-picker" id="duo-pr-from-picker">
                                <div class="selected-rank" id="duo-pr-from-selected" role="button" tabindex="0"
                                    aria-haspopup="listbox" aria-expanded="false">
                                    <img src="/assets/1 - IRON.webp" alt="Iron" class="selected-rank-img" width="60"
                                        height="60" />
                                    <div class="selected-rank-info">
                                        <span class="selected-rank-name">Iron</span>
                                        <span class="selected-rank-division">Division 1</span>
                                    </div>
                                    <svg class="dropdown-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M6 9l6 6 6-6" />
                                    </svg>
                                </div>
                                <div class="rank-dropdown" id="duo-pr-from-dropdown">
                                    <div class="rank-options" id="duo-pr-from-options"></div>
                                </div>
                            </div>
                            <div class="division-selector" id="duo-pr-from-division">
                                <button type="button" class="division-btn active" data-division="1">I</button>
                                <button type="button" class="division-btn" data-division="2">II</button>
                                <button type="button" class="division-btn" data-division="3">III</button>
                            </div>
                            <div class="rr-input-container" id="duo-pr-from-regular-rr-container">
                                <label class="rr-label" for="duo-pr-from-regular-rr">{t('calc.currentRR', lang)}</label>
                                <div class="rr-input-wrapper">
                                    <input type="number" class="rr-input" id="duo-pr-from-regular-rr" min="0" max="99"
                                        value="0" placeholder="0">
                                    <span class="rr-suffix">RR</span>
                                </div>
                            </div>
                            <div class="rr-input-container" id="duo-pr-from-rr-container" style="display: none;">
                                <label class="rr-label" for="duo-pr-from-rr">Rating Points (RR)</label>
                                <div class="rr-input-wrapper">
                                    <input type="number" class="rr-input" id="duo-pr-from-rr" min="0" max="1000"
                                        value="0" placeholder="0">
                                    <span class="rr-suffix">RR</span>
                                </div>
                            </div>
                        </div>

                        <!-- Arrow -->
                        <div class="calculator-arrow">
                            <div class="arrow-circle">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" aria-hidden="true">
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            </div>
                        </div>

                        <!-- To Rank -->
                        <div class="rank-selector">
                            <h3 class="selector-title">
                                <span>{t('duo.perrank.to', lang)}</span>
                            </h3>
                            <div class="rank-picker" id="duo-pr-to-picker">
                                <div class="selected-rank" id="duo-pr-to-selected" role="button" tabindex="0"
                                    aria-haspopup="listbox" aria-expanded="false">
                                    <img src="/assets/4 - GOLD.webp" alt="Gold" class="selected-rank-img" width="60"
                                        height="60" />
                                    <div class="selected-rank-info">
                                        <span class="selected-rank-name">Gold</span>
                                        <span class="selected-rank-division">Division 1</span>
                                    </div>
                                    <svg class="dropdown-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M6 9l6 6 6-6" />
                                    </svg>
                                </div>
                                <div class="rank-dropdown" id="duo-pr-to-dropdown">
                                    <div class="rank-options" id="duo-pr-to-options"></div>
                                </div>
                            </div>
                            <div class="division-selector" id="duo-pr-to-division">
                                <button type="button" class="division-btn active" data-division="1">I</button>
                                <button type="button" class="division-btn" data-division="2">II</button>
                                <button type="button" class="division-btn" data-division="3">III</button>
                            </div>
                            <div class="rr-input-container" id="duo-pr-to-rr-container" style="display: none;">
                                <label class="rr-label" for="duo-pr-to-rr">Rating Points (RR)</label>
                                <div class="rr-input-wrapper">
                                    <input type="number" class="rr-input" id="duo-pr-to-rr" min="0" max="1000"
                                        value="50" placeholder="50">
                                    <span class="rr-suffix">RR</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RR Info Display -->
                    <div class="rr-info-bar" id="duo-pr-rr-info-bar" style="display: none;">
                        <div class="rr-info-content">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" aria-hidden="true">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="16" x2="12" y2="12" />
                                <line x1="12" y1="8" x2="12.01" y2="8" />
                            </svg>
                            <span id="duo-pr-rr-info-text"></span>
                        </div>
                    </div>

                    <!-- Price Display -->
                    <div class="price-display duo-price-display">
                        <div class="price-info">
                            <span class="price-label">{t('duo.perrank.priceLabel', lang)}</span>
                            <div class="original-price" id="duo-pr-original-price"></div>
                            <div class="price-amount">
                                <span class="currency">Rp</span>
                                <span class="price-value" id="duo-pr-price-value">0</span>
                            </div>
                            <div class="discount-badge" id="duo-pr-discount-badge"></div>
                            <span class="price-note">{t('duo.perrank.priceNote', lang)}</span>
                        </div>
                        <a href="#" target="_blank" rel="noopener" class="btn btn-primary btn-lg order-btn"
                            id="duo-pr-order-btn">
                            <WaIcon size={24} />
                            <span>{t('duo.perrank.order', lang)}</span>
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>
