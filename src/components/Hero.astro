---
import { t } from '../data/i18n.js'
const { lang = 'id' } = Astro.props
---
<section class="hero" id="home">
    <div class="hero-bg">
        <div class="hero-gradient"></div>
    </div>
    <div class="container hero-container">
        <div class="hero-content">
            <p class="hero-badge">{t('hero.badge', lang)}</p>
            <h1 class="hero-title" set:html={t('hero.title', lang)} />
            <p class="hero-description">{t('hero.description', lang)}</p>
            <div class="hero-buttons">
                <a href="#calculator" class="btn btn-primary btn-lg">
                    <span>{t('hero.cta', lang)}</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="#services" class="btn btn-outline btn-lg">{t('hero.cta2', lang)}</a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-number" data-count-up="1000" data-suffix="+">0</span>
                    <span class="stat-label">{t('hero.stat.orders', lang)}</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number" data-count-up="100" data-suffix="%">0</span>
                    <span class="stat-label">{t('hero.stat.satisfaction', lang)}</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number" data-count-up-special="24/7">24/7</span>
                    <span class="stat-label">Support</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="rank-showcase">
                <img src="/assets/9 - RADIANT.webp" alt={lang === 'id' ? 'Rank Radiant Valorant' : 'Valorant Radiant Rank'}
                    class="showcase-rank" width="200" height="200" fetchpriority="high" />
                <div class="rank-glow"></div>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <span>{t('hero.scroll', lang)}</span>
        <div class="scroll-arrow"></div>
    </div>
</section>
