---
import { t } from '../data/i18n.js'
const { lang = 'id' } = Astro.props

const features = [
    {
        key: 'fast',
        icon: '<circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />',
    },
    {
        key: 'safe',
        icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />',
    },
    {
        key: 'support',
        icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />',
    },
    {
        key: 'expert',
        icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />',
    },
    {
        key: 'price',
        icon: '<rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" />',
    },
    {
        key: 'guarantee',
        icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />',
    },
]
---
<section class="why-us-section" id="why-us">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">{t('why.badge', lang)}</span>
            <h2 class="section-title" set:html={t('why.title', lang)} />
            <p class="section-description">{t('why.description', lang)}</p>
        </div>

        <div class="features-grid">
            {features.map((f) => (
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true" set:html={f.icon} />
                    </div>
                    <h3 class="feature-title">{t(`why.${f.key}.title`, lang)}</h3>
                    <p class="feature-description">{t(`why.${f.key}.desc`, lang)}</p>
                </div>
            ))}

            <!-- Mobile clones for seamless infinite scroll -->
            {features.map((f) => (
                <div class="feature-card mobile-clone" aria-hidden="true">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" aria-hidden="true" set:html={f.icon} />
                    </div>
                    <h3 class="feature-title">{t(`why.${f.key}.title`, lang)}</h3>
                    <p class="feature-description">{t(`why.${f.key}.desc`, lang)}</p>
                </div>
            ))}
        </div>
    </div>
</section>
