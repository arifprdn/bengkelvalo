---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import FloatingWa from '../../components/FloatingWa.astro'

const lang = 'id'

const posts = [
    {
        href: '/blog/distribusi-rank-valorant/',
        title: 'Distribusi Rank Valorant 2026: Kamu di Persentil Berapa?',
        desc: 'Persentase pemain di tiap tier Iron–Radiant, di mana letak median rank, dan cara membaca posisimu untuk menentukan target yang realistis.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/rr-naik-sedikit-turun-banyak/',
        title: 'Kenapa RR Naik Sedikit tapi Turun Banyak? Penjelasan MMR',
        desc: 'MMR tersembunyi vs rank tampilan: kenapa kemenanganmu cuma dihargai belasan RR, tanda-tandanya, dan cara memperbaikinya.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/cara-cek-mmr-valorant/',
        title: 'Cara Cek MMR Valorant (Riot Tidak Menampilkannya)',
        desc: 'MMR tidak bisa dilihat langsung — tapi bisa diperkirakan dari pola RR gain/loss dan tracker pihak ketiga. Ini caranya.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/hardstuck-valorant/',
        title: 'Hardstuck Valorant: 5 Penyebab & Cara Keluarnya',
        desc: 'Ratusan game tanpa progres bukan soal skill semata — kenali pola auto-pilot, tilt, dan mental block yang menahanmu di rank yang sama.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/tips-placement-match-valorant/',
        title: '7 Tips Menang Placement Match Valorant',
        desc: 'Cara mengeksekusi 5 match placement dengan benar: kapan main, agent apa, dan kesalahan umum yang membuat posisi awalmu jelek satu season.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/immortal-ke-radiant/',
        title: 'Kenapa Immortal ke Radiant Sesusah Itu?',
        desc: 'Radiant adalah kuota leaderboard regional, bukan sekadar tier berikutnya. Matematika RR-nya dan jalur realistis mengejarnya.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/smurf-valorant/',
        title: 'Kenapa Banyak Smurf di Rank Rendah Valorant?',
        desc: 'Kenapa smurf menumpuk di Iron–Gold, cara mengenalinya di match-mu, dan cara menghadapinya tanpa tilt.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/solo-queue-vs-5-stack/',
        title: 'Solo Queue vs 5-Stack: Kenapa RR-mu Dipotong?',
        desc: 'Aturan party ranked, penalti RR untuk stack beda rank jauh, dan cara push rank bareng teman tanpa rugi progres.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/apa-itu-joki-valorant/',
        title: 'Apa Itu Joki Valorant? Jenis, Cara Kerja, dan Biayanya',
        desc: 'Definisi joki, beda joki akun vs gendong vs satuan vs placement, alur prosesnya dari order sampai selesai, dan kisaran biayanya.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/berapa-lama-joki-valorant/',
        title: 'Berapa Lama Joki Valorant? Estimasi Durasi per Rank',
        desc: 'Estimasi jujur: game per divisi, durasi per tier, dan faktor yang mempercepat atau memperlambat pengerjaan.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/reset-rank-valorant/',
        title: 'Reset Rank Valorant: Cara Kerja Episode, Act, dan Placement',
        desc: 'Kapan rank di-reset, berapa banyak turunnya, dan kenapa 5 match placement menentukan satu season penuh.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/harga-pasaran-joki-valorant/',
        title: 'Harga Pasaran Joki Valorant 2026: Hasil Survei 6 Penyedia + Marketplace',
        desc: 'Data rentang harga per divisi Iron–Radiant dari survei pasar Juli 2026, cara membacanya, dan kenapa harga terlalu murah adalah lampu merah.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/apakah-joki-valorant-aman/',
        title: 'Apakah Joki Valorant Aman? Risiko Sebenarnya & Cara Kami Menjaganya',
        desc: 'Jawaban jujur soal risiko ban, ciri joki penipu yang wajib dihindari, dan checklist keamanan sebelum menyerahkan akun.',
        date: 'Juli 2026',
    },
    {
        href: '/blog/cara-naik-rank-valorant/',
        title: 'Cara Naik Rank Valorant dengan Cepat (Panduan 2026)',
        desc: 'Cara kerja RR, 5 kesalahan yang bikin hardstuck, estimasi waktu per rank, dan kapan jasa joki masuk akal.',
        date: 'Juli 2026',
    },
]
---
<Base lang={lang} title="Blog & Panduan Valorant | BengkelValo"
    description="Panduan rank, tips naik rank, dan info seputar joki Valorant dari tim BengkelValo — jasa joki Valorant terpercaya di Indonesia."
    path="/blog/">

    <Nav lang={lang} onHome={false} />

    <main class="pricing-page">
        <div class="container">
            <div class="section-header pricing-page-header">
                <span class="section-badge">Blog</span>
                <h1 class="section-title">Panduan &amp; <span class="gradient-text">Tips Valorant</span></h1>
                <p class="section-description">Panduan naik rank dan info seputar dunia joki — ditulis tim yang
                    mengerjakan ribuan game ranked.</p>
            </div>

            <div class="blog-list">
                {posts.map((p) => (
                    <a href={p.href} class="blog-list-item">
                        <p class="testimonial-meta">{p.date}</p>
                        <h2 class="step-title">{p.title}</h2>
                        <p class="step-desc">{p.desc}</p>
                    </a>
                ))}
            </div>
        </div>
    </main>

    <Footer lang={lang} onHome={false} />
    <FloatingWa lang={lang} />

    <script src="../../scripts/main.js"></script>
</Base>
